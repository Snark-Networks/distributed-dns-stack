# CoreDNS — Authoritative DNS server
# Listens on port 5300 (all interfaces — accessible by dnsdist frontends)
#
# Metrics endpoint: http://{{ coredns_prometheus_address }}/metrics
#
# Plugin chain per zone:
#   file        — serves SOA, NS, and explicit PTR records from the zone file;
#                 falls through to the template when no PTR record is found
#   template    — catch-all: auto-generates PTR for any IP not in the zone file
#
# Explicit PTR records live in the zone files (zones/db.*), not here.
# Edit those files and run "make deploy-zones" to apply — no container restart needed.
# Only the catch-all template lives here, because dynamic PTR generation
# cannot be expressed in a standard zone file.
#
# This file is a Jinja2 template rendered by Ansible at deploy time.
# {{ coredns_prometheus_address }} is set in group_vars/coredns_servers.yml.
# CoreDNS Go template syntax (.Name, .Group.x, etc.) inside answer lines is
# protected from Jinja2 processing by raw/endraw blocks.

# ---------------------------------------------------------------------------
# IPv4 Reverse DNS: 192.0.2.0/24
# ---------------------------------------------------------------------------
2.0.192.in-addr.arpa.:5300 {
    file /zones/db.2.0.192.in-addr.arpa {
        reload 60s
        fallthrough
    }

{% raw %}
    # Catch-all: auto-generate PTR for any IP not in the zone file.
    # Example: 192.0.2.200 -> 192-0-2-200.example.com.
    template IN PTR 2.0.192.in-addr.arpa. {
        match ^(?P<octet>[0-9]+)\.2\.0\.192\.in-addr\.arpa\.$
        answer "{{ .Name }} 3600 IN PTR 192-0-2-{{ .Group.octet }}.example.com."
    }
{% endraw %}

    transfer {
        to *
    }
    prometheus {{ coredns_prometheus_address }}
    log
    errors
    health :8080
    reload
}

# ---------------------------------------------------------------------------
# IPv6 Reverse DNS: 2001:db8::/40
#
# /40 prefix means 22 variable nibbles (32 - 10 = 22).
# n1 = LSB of address, n22 = MSB of variable portion.
# The 3rd IPv6 group starts with fixed nibbles "00" from the zone prefix,
# so the hostname prepends "00" before the first two variable nibbles (n22, n21).
# Example: 2001:db8:00f9:0002::0013:0001 -> ip6-00f9-0002-0000-0000-0013-0001.example.com
# ---------------------------------------------------------------------------
0.0.8.b.d.0.1.0.0.2.ip6.arpa.:5300 {
    file /zones/db.0.0.8.b.d.0.1.0.0.2.ip6.arpa {
        reload 60s
        fallthrough
    }

{% raw %}
    # Catch-all: auto-generate PTR for any IPv6 not in the zone file.
    template IN PTR 0.0.8.b.d.0.1.0.0.2.ip6.arpa. {
        match ^(?P<n1>[0-9a-f])\.(?P<n2>[0-9a-f])\.(?P<n3>[0-9a-f])\.(?P<n4>[0-9a-f])\.(?P<n5>[0-9a-f])\.(?P<n6>[0-9a-f])\.(?P<n7>[0-9a-f])\.(?P<n8>[0-9a-f])\.(?P<n9>[0-9a-f])\.(?P<n10>[0-9a-f])\.(?P<n11>[0-9a-f])\.(?P<n12>[0-9a-f])\.(?P<n13>[0-9a-f])\.(?P<n14>[0-9a-f])\.(?P<n15>[0-9a-f])\.(?P<n16>[0-9a-f])\.(?P<n17>[0-9a-f])\.(?P<n18>[0-9a-f])\.(?P<n19>[0-9a-f])\.(?P<n20>[0-9a-f])\.(?P<n21>[0-9a-f])\.(?P<n22>[0-9a-f])\.0\.0\.8\.b\.d\.0\.1\.0\.0\.2\.ip6\.arpa\.$
        answer "{{ .Name }} 3600 IN PTR ip6-00{{ .Group.n22 }}{{ .Group.n21 }}-{{ .Group.n20 }}{{ .Group.n19 }}{{ .Group.n18 }}{{ .Group.n17 }}-{{ .Group.n16 }}{{ .Group.n15 }}{{ .Group.n14 }}{{ .Group.n13 }}-{{ .Group.n12 }}{{ .Group.n11 }}{{ .Group.n10 }}{{ .Group.n9 }}-{{ .Group.n8 }}{{ .Group.n7 }}{{ .Group.n6 }}{{ .Group.n5 }}-{{ .Group.n4 }}{{ .Group.n3 }}{{ .Group.n2 }}{{ .Group.n1 }}.example.com."
    }
{% endraw %}

    transfer {
        to *
    }
    prometheus {{ coredns_prometheus_address }}
    log
    errors
    reload
}
