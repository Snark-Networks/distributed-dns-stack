global:
  scrape_interval:     15s
  evaluation_interval: 15s
  external_labels:
    monitor: {{ inventory_hostname }}

scrape_configs:
{% for host in groups['dnsdist_servers'] | default([]) %}
  # ── {{ host }} (dnsdist frontend) ────────────────────────────────────────────
  # Scrape target IP is controlled by metrics_scrape_address in hosts.yml.
  # Default: 127.0.0.1 (all-in-one). Set to the host's IP for split deployments.
  - job_name: dnsdist_{{ host }}
    static_configs:
      - targets: ['{{ hostvars[host]["metrics_scrape_address"] | default("127.0.0.1") }}:8083']
        labels:
          instance: {{ host }}
    metrics_path: /metrics
    basic_auth:
      username: dnsdist
      # dnsdist_webserver_password is set in group_vars/all.yml
      password: "{{ dnsdist_webserver_password }}"

{% endfor %}
{% for host in groups['coredns_servers'] | default([]) %}
  # ── {{ host }} (CoreDNS backend) ─────────────────────────────────────────────
  - job_name: coredns_{{ host }}
    static_configs:
      - targets: ['{{ hostvars[host]["metrics_scrape_address"] | default("127.0.0.1") }}:9153']
        labels:
          instance: {{ host }}
    metrics_path: /metrics

{% endfor %}
  # ── Prometheus self-monitoring ────────────────────────────────────────────
  - job_name: prometheus
    static_configs:
      - targets: ['127.0.0.1:9090']
